<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
  </head>
  <body>
    <%- include('partials/site-header', { content }) %>

    <main class="subpage">
      <div class="container">
        <header class="subpage__head">
          <span class="subpage__kicker">CONTACT ATEX</span>
          <h1 class="subpage__title">تواصل مع فريق اتكس</h1>
          <p class="subpage__desc">يسعدنا الإجابة عن استفساراتكم وتقديم الاستشارة المناسبة لمشروعكم، مع تصور مبدئي واضح لمسار التنفيذ والمدة المتوقعة.</p>
        </header>

        <div class="subpage__panel">
          <form id="contactForm" class="cta__form" novalidate>
            <div class="field">
              <label class="field__label" for="contactName">الاسم</label>
              <input class="field__input" id="contactName" name="name" type="text" placeholder="الاسم الكامل" required />
            </div>
            <div class="field">
              <label class="field__label" for="contactEmail">البريد الإلكتروني</label>
              <input class="field__input" id="contactEmail" name="email" type="email" placeholder="name@example.com" required dir="ltr" />
            </div>
            <div class="field">
              <label class="field__label" for="contactMessage">الرسالة</label>
              <textarea class="field__input" id="contactMessage" name="message" rows="5" placeholder="اكتب تفاصيل المشروع أو الاستفسار" required></textarea>
            </div>
            <p class="formNote is-info" data-contact-note>سنقوم بالتواصل معك في أقرب وقت ممكن.</p>
            <button class="btn btn--primary" type="submit" data-contact-submit>إرسال</button>
          </form>
          <div class="contactQuickActions">
            <a class="btn btn--primary" href="https://wa.me/966580102121" target="_blank" rel="noopener noreferrer">تواصل عبر واتساب</a>
            <a class="btn btn--ghost" href="tel:+966580102121" dir="ltr">+966 58 010 2121</a>
            <a class="btn btn--ghost" href="mailto:contact@atex.sa" dir="ltr">contact@atex.sa</a>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/site-footer', { content }) %>
  </body>
</html>
