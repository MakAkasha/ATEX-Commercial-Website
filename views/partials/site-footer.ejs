<footer class="footer footer--v2">
  <% const __homeContent = (typeof content !== 'undefined') ? content : null; %>
  <% const __email = (__homeContent?.contact?.email || 'contact@atex.sa'); %>
  <div class="container">
    <!-- Top: brand + CTA -->
    <div class="footer__top">
      <div class="footer__brand">
        <a class="footer__brandLogo" href="/" aria-label="ATEX">
          <img src="/assets/ATEX-footer-logo.svg" alt="ATEX" />
        </a>
        <p class="footer__tagline">ذكاء متكامل ... تحكم بلا حدود</p>
        <p class="footer__desc">شركة سعودية متخصصة في حلول إنترنت الأشياء للشركات — من التصميم إلى التشغيل.</p>
      </div>
      <div class="footer__map" aria-label="موقع أتكس على الخريطة">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3711.905082875168!2d39.184737575551324!3d21.51143748026141!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x15c3cfc39c08669b%3A0xeff744e629dd2e00!2z2KfYqtmD2LM!5e0!3m2!1sen!2ssa!4v1782903414981!5m2!1sen!2ssa"
          title="موقع أتكس على خرائط جوجل"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"></iframe>
      </div>
    </div>

    <!-- Link columns -->
    <div class="footer__grid">
      <nav class="footer__col" aria-label="روابط سريعة">
        <h4 class="footer__label">روابط سريعة</h4>
        <div class="footer__links">
          <a class="footer__link" href="/">الصفحة الرئيسية</a>
          <a class="footer__link" href="/solutions">الحلول والخدمات</a>
          <a class="footer__link" href="/products">بعض المنتجات</a>
          <a class="footer__link" href="/blog">المدونة والمقالات</a>
          <a class="footer__link" href="/contact-us">تواصل معنا</a>
        </div>
      </nav>

      <div class="footer__col">
        <h4 class="footer__label">الدعم والتواصل</h4>
        <div class="footer__links">
          <a class="footer__link footer__link--soon" role="link" tabindex="0" aria-label="منصة الدعم الفني — قريباً" title="قريباً" data-href="https://help.atex.sa">منصة الدعم الفني <span class="footer__soon" aria-hidden="true">قريباً</span></a>
          <a class="footer__link" href="mailto:<%= __email %>">إرسال بريد إلكتروني</a>
          <div class="footer__contact">
            <button class="footer__link footer__contactBtn" type="button" aria-haspopup="true">خدمة العملاء</button>
            <div class="footer__pop" role="group" aria-label="التواصل مع خدمة العملاء">
              <a class="footer__popBtn footer__popBtn--wa" href="https://wa.me/966580102121" target="_blank" rel="noopener noreferrer" aria-label="واتساب خدمة العملاء"><i class="fa-brands fa-whatsapp" aria-hidden="true"></i></a>
              <a class="footer__popBtn" href="tel:0580102121" aria-label="اتصال خدمة العملاء"><i class="fa-solid fa-phone" aria-hidden="true"></i></a>
            </div>
          </div>
          <div class="footer__contact">
            <button class="footer__link footer__contactBtn" type="button" aria-haspopup="true">قسم المبيعات</button>
            <div class="footer__pop" role="group" aria-label="التواصل مع قسم المبيعات">
              <a class="footer__popBtn footer__popBtn--wa" href="https://wa.me/966509330008" target="_blank" rel="noopener noreferrer" aria-label="واتساب قسم المبيعات"><i class="fa-brands fa-whatsapp" aria-hidden="true"></i></a>
              <a class="footer__popBtn" href="tel:0509330008" aria-label="اتصال قسم المبيعات"><i class="fa-solid fa-phone" aria-hidden="true"></i></a>
            </div>
          </div>
        </div>
      </div>

      <nav class="footer__col" aria-label="روابط قانونية">
        <h4 class="footer__label">قانوني</h4>
        <div class="footer__links">
          <a class="footer__link" href="/privacy">سياسة الخصوصية</a>
          <a class="footer__link" href="/terms">الشروط والأحكام</a>
        </div>
      </nav>

      <div class="footer__col">
        <h4 class="footer__label">العنوان</h4>
        <div class="footer__links">
          <a class="footer__link footer__meta" href="https://maps.app.goo.gl/SXCnFM3kn96yRbk58" target="_blank" rel="noopener noreferrer">مركز الهدى للأعمال، الشرفية، جدة</a>
          <span class="footer__meta">الرقم الوطني الموحد: <span dir="ltr">7051668007</span></span>
          <span class="footer__meta">الرقم الضريبي: <span dir="ltr">314231577900003</span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottomInner">
      <span class="footer__copyright">© 2026 إي تي إي إكس التجارية. جميع الحقوق محفوظة</span>
      <span class="footer__version" dir="ltr">v4.5.48</span>
    </div>
  </div>

  <div class="footer__watermark" aria-hidden="true">ATEX</div>
</footer>

<script>
  (function () {
    var items = Array.prototype.slice.call(document.querySelectorAll('.footer--v2 .footer__contact'));
    if (!items.length) return;
    function closeAll(except) {
      items.forEach(function (it) {
        if (it === except) return;
        it.classList.remove('is-open');
        var b = it.querySelector('.footer__contactBtn');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }
    items.forEach(function (it) {
      var btn = it.querySelector('.footer__contactBtn');
      if (!btn) return;
      btn.setAttribute('aria-expanded', 'false');
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = it.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(open));
        closeAll(it);
      });
    });
    document.addEventListener('click', function () { closeAll(null); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAll(null); });
  })();
</script>

<!-- GSAP -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
