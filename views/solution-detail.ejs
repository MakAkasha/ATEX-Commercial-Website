<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
    <%- include('partials/structured-data') %>
  </head>
  <body>
    <%- include('partials/site-header', { content }) %>

    <main class="solutionsPage solutionDetailPage" id="main-content" tabindex="-1">
      <section class="section solutionsPage__hero" aria-label="تفاصيل الحل">
        <div class="container solutionsPage__heroInner">
          <div class="solutionsPage__heroCopy">
            <nav class="breadcrumbs" aria-label="مسار الصفحة">
              <a href="/">الرئيسية</a>
              <span>/</span>
              <a href="/solutions">الحلول</a>
              <span>/</span>
              <strong><%= solution.title %></strong>
            </nav>
            <span class="solutionsPage__eyebrow">ATEX Solution Detail</span>
            <h1 class="solutionsPage__title"><%= solution.title %></h1>
            <p class="solutionsPage__desc"><%= solution.summary %></p>

            <div class="solutionsPage__heroActions">
              <a class="btn btn--primary" href="/contact-us">اطلب استشارة لهذا الحل</a>
              <a class="btn btn--ghost" href="/solutions">العودة إلى جميع الحلول</a>
            </div>
          </div>

          <div class="solutionsPage__heroMedia solutionsPage__heroMedia--single" aria-hidden="true">
            <figure class="solutionsPage__heroPrimary">
              <img src="<%= solution.primaryImage || '/assets/ATEX-logo.svg' %>" alt="<%= solution.title %>" loading="lazy" onerror="this.onerror=null;this.src='/assets/ATEX-logo.svg'" />
            </figure>
          </div>
        </div>
      </section>

      <section class="section" id="solution-detail-content">
        <div class="container">
          <article class="solutionsPage__detail" aria-labelledby="solution-detail-title">
            <div class="solutionsPage__detailBody">
              <div class="solutionsPage__detailHeader">
                <p class="solutionsPage__detailKicker" dir="ltr">Solution Detail</p>
                <h3 id="solution-detail-title"><%= solution.title %></h3>
                <div class="solutionsPage__useCases">
                  <% (solution.useCases || []).slice(0, 3).forEach(function(u){ %>
                    <span><%= u %></span>
                  <% }) %>
                </div>
              </div>

              <div class="solutionsPage__detailIntro">
                <p class="solutionsPage__detailSummary"><%= solution.summary %></p>
                <p class="solutionsPage__detailText"><%= solution.details %></p>
              </div>

              <% if (Array.isArray(solution.benefits) && solution.benefits.length) { %>
                <div class="solutionsPage__detailMeta">
                  <section class="solutionsPage__metaBlock subpage__fullCol">
                    <h4>القيمة المضافة</h4>
                    <div class="solutionsPage__useCases">
                      <% solution.benefits.forEach(function(item){ %>
                        <span><%= item %></span>
                      <% }) %>
                    </div>
                  </section>
                </div>
              <% } %>

              <div class="solutionsPage__detailMeta">
                <section class="solutionsPage__metaBlock">
                  <h4>القدرات الأساسية</h4>
                  <ul>
                    <% (solution.features || []).forEach(function(f){ %>
                      <li><%= f %></li>
                    <% }) %>
                  </ul>
                </section>

                <section class="solutionsPage__metaBlock">
                  <h4>حالات استخدام مناسبة</h4>
                  <div class="solutionsPage__useCases">
                    <% (solution.useCases || []).forEach(function(u){ %>
                      <span><%= u %></span>
                    <% }) %>
                  </div>
                </section>
              </div>

              <% if (solution.pageGoal || solution.longIntro) { %>
                <div class="solutionsPage__detailMeta">
                  <% if (solution.pageGoal) { %>
                    <section class="solutionsPage__metaBlock">
                      <h4>هدف الحل</h4>
                      <p class="solutionsPage__detailText"><%= solution.pageGoal %></p>
                    </section>
                  <% } %>
                  <% if (solution.longIntro) { %>
                    <section class="solutionsPage__metaBlock">
                      <h4>نظرة أوسع</h4>
                      <p class="solutionsPage__detailText"><%= solution.longIntro %></p>
                    </section>
                  <% } %>
                </div>
              <% } %>

              <% if (Array.isArray(solution.faqs) && solution.faqs.length) { %>
                <section class="solutionsPage__metaBlock subpage__fullCol">
                  <h4>أسئلة شائعة</h4>
                  <div class="faq" role="list">
                    <% solution.faqs.forEach(function(item, idx){ %>
                      <div class="faq__item" role="listitem">
                        <button class="faq__q" type="button" aria-expanded="false" aria-controls="faq-answer-<%= idx %>"><%= item.q %> <span class="faq__icon" aria-hidden="true">+</span></button>
                        <div class="faq__a" id="faq-answer-<%= idx %>" role="region"><%= item.a %></div>
                      </div>
                    <% }) %>
                  </div>
                </section>
              <% } %>

              <div class="solutionsPage__detailActions">
                <a class="btn btn--primary btn--small" href="/contact-us"><%= solution.ctaLabel || 'اطلب عرضاً لهذا الحل' %></a>
                <a class="btn btn--ghost btn--small" href="https://wa.me/966580102121" target="_blank" rel="noopener noreferrer">تواصل واتساب</a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <% if (Array.isArray(relatedIndustries) && relatedIndustries.length) { %>
        <section class="section" aria-label="قطاعات مرتبطة">
          <div class="container">
            <div class="section__head">
              <p class="solutionsPage__sectionKicker">RELATED INDUSTRIES</p>
              <h2>قطاعات يرتبط بها هذا الحل</h2>
            </div>
            <%- include('partials/industries-grid', { items: relatedIndustries }) %>
          </div>
        </section>
      <% } %>

      <% if (Array.isArray(relatedSolutions) && relatedSolutions.length) { %>
        <section class="section" aria-label="حلول ذات صلة">
          <div class="container">
            <div class="section__head">
              <p class="solutionsPage__sectionKicker">RELATED SOLUTIONS</p>
              <h2>حلول أخرى قد تهمكم</h2>
              <p>اطّلع على حلول إضافية ضمن نفس منظومة اتكس الذكية.</p>
            </div>

            <%- include('partials/solutions-grid', { items: relatedSolutions }) %>
          </div>
        </section>
      <% } %>
    </main>

    <%- include('partials/site-footer', { content }) %>
  </body>
</html>
