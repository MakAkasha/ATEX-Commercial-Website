<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
    <%- include('partials/structured-data') %>
  </head>
  <body>
    <%- include('partials/site-header') %>
    <main class="subpage" id="main-content" tabindex="-1">
      <div class="container">
        <nav class="breadcrumbNav" aria-label="مسار التنقل">
          <ol class="breadcrumbNav__list">
            <li class="breadcrumbNav__item"><a href="/">الرئيسية</a></li>
            <li class="breadcrumbNav__item breadcrumbNav__item--current" aria-current="page">المدونة</li>
          </ol>
        </nav>

        <header class="subpage__head">
          <h1 class="subpage__title">المدونة</h1>
          <p class="subpage__desc">مقالات وأفضل الممارسات في حلول إنترنت الأشياء داخل السعودية، مع رؤى عملية تساعدكم على اتخاذ قرارات تقنية مدروسة.</p>
        </header>

        <section class="blogIntroPanel" aria-label="ملخص المدونة">
          <div class="blogIntroPanel__item">
            <strong>محتوى عملي</strong>
            <span>مقالات مبنية على حالات تطبيق واقعية في المشاريع الذكية.</span>
          </div>
          <div class="blogIntroPanel__item">
            <strong>رؤية تنفيذية</strong>
            <span>تركيز على القرارات التي تخدم التشغيل والكفاءة والاستدامة.</span>
          </div>
          <div class="blogIntroPanel__item">
            <strong>تحديثات مستمرة</strong>
            <span>محتوى متجدد حول المنصات، التكاملات، وأفضل الممارسات.</span>
          </div>
        </section>

        <div class="blogGrid">
          <% posts.forEach(function(p){ %>
            <article class="blogCard" data-tilt>
              <a href="/blog/<%= p.slug %>" aria-label="<%= p.title %>">
                <div class="blogCard__media">
                  <% if (p.cover_image) { %>
                    <img src="<%= p.cover_image %>" alt="" loading="lazy" />
                  <% } else { %>
                    <div class="blogCard__mediaFallback">ATEX</div>
                  <% } %>
                </div>
                <div class="blogCard__body">
                  <div class="blogCard__meta">
                    <% if (p.tags && p.tags.length) { %>
                      <span class="blogCard__pill"><%= p.tags[0] %></span>
                    <% } else { %>
                      <span class="blogCard__pill">Insight</span>
                    <% } %>
                    <div class="blogCard__metaRight">
                      <% if (p.readingTime) { %>
                        <span class="blogReadingTime"><i class="fa-regular fa-clock" aria-hidden="true"></i> <%= p.readingTime %> د</span>
                      <% } %>
                      <% if (p.formattedDate) { %><time dir="ltr" datetime="<%= p.isoPublished || '' %>"><%= p.formattedDate %></time><% } %>
                    </div>
                  </div>
                  <h3 class="blogCard__title"><%= p.title %></h3>
                  <p class="blogCard__desc"><%= p.excerpt %></p>
                  <% if (p.tags && p.tags.length > 1) { %>
                    <div class="blogTagChips">
                      <% p.tags.slice(0, 4).forEach(function(tag){ %>
                        <span class="blogTagChip"><%= tag %></span>
                      <% }) %>
                    </div>
                  <% } %>
                  <div class="blogCard__footer"><span class="btn btn--ghost btn--small">اقرأ المقال</span></div>
                </div>
              </a>
            </article>
          <% }) %>
        </div>

        <% if (!posts || posts.length === 0) { %>
          <div class="blogEmpty">
            <p>لا توجد مقالات منشورة حالياً. تابعونا قريباً.</p>
          </div>
        <% } %>
      </div>

      <%- include('partials/final-cta', {
        heading: 'هل تريد تطبيق هذه الرؤى في مشروعك؟',
        subheading: 'استفد من خبرات فريقنا الفني لتحويل هذه الأفكار إلى حلول وتقنيات ملموسة.',
        mainAction: '<a class="btn btn--primary" href="/contact-us">ابدأ المناقشة الفنية</a>',
        cardHeading: 'دعنا نبني مستقبلك الذكي',
        cardDesc: 'فريقنا مستعد لتزويدك بأفضل ممارسات السوق وتطبيقها فوراً في منشأتك.'
      }) %>
    </main>
    <%- include('partials/site-footer') %>
  </body>
</html>
