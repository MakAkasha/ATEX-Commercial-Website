<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
  </head>
  <body>
    <%- include('partials/site-header') %>
    <main class="subpage">
      <div class="container">
        <header class="subpage__head">
          <span class="subpage__kicker">ARTICLE</span>
          <h1 class="subpage__title"><%= post.title %></h1>
          <div class="blogPostHeadMeta">
            <div class="subpage__meta" dir="ltr"><%= post.created_at %></div>
            <span class="blogPostHeadMeta__pill">ATEX Insight</span>
          </div>
        </header>
        <article class="subpage__panel blogPostLayout">
          <header class="blogPostLayout__intro">
            <p class="subpage__desc">قراءة عملية من فريق اتكس تربط التقنية بالتشغيل اليومي واحتياجات المشاريع في السوق السعودي.</p>
          </header>
          <% if (post.cover_image) { %>
            <div class="subpage__cover"><img src="<%= post.cover_image %>" alt="<%= post.title %>" /></div>
          <% } %>
          <%
            let articleHtml = post.content_html || '';
            if (post.cover_image) {
              const escapedSrc = String(post.cover_image).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
              const duplicateCoverImgRegex = new RegExp(`<img[^>]*src=["']${escapedSrc}["'][^>]*>`, 'i');
              articleHtml = articleHtml.replace(duplicateCoverImgRegex, '');
              articleHtml = articleHtml.replace(/<p>\s*<\/p>/gi, '');
            }
          %>
          <div class="richText blogPostContent"><%- articleHtml %></div>
          <footer class="blogPostFooter">
            <div class="blogPostFooter__note">تم إعداد هذا المحتوى لمساعدة فرق التشغيل والهندسة على اتخاذ قرارات أكثر دقة.</div>
            <div class="subpage__back">
              <a class="btn btn--ghost btn--small" href="/blog">رجوع للمدونة</a>
            </div>
          </footer>
        </article>
      </div>
    </main>
    <%- include('partials/site-footer') %>
  </body>
</html>
