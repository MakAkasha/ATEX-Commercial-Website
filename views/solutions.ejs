<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
    <%- include('partials/structured-data') %>
  </head>
  <body>
    <%- include('partials/site-header', { content }) %>

    <% const solutions = Array.isArray(pageSolutions) ? pageSolutions : []; %>

    <main class="solutionsPage" id="main-content" tabindex="-1">
      <section class="section solutionsPage__hero" aria-label="مقدمة الأنظمة والحلول">
        <div class="container solutionsPage__heroInner">
          <div class="solutionsPage__heroCopy">
            <span class="solutionsPage__eyebrow">اتكس Solutions</span>
            <h1 class="solutionsPage__title">حلول ذكية متكاملة لرفع كفاءة مشاريعكم</h1>
            <p class="solutionsPage__desc">
              اكتشفوا حلول اتكس في صفحة واحدة منظمة، ثم انتقلوا إلى صفحة مستقلة لكل حل للاطلاع على التفاصيل الفنية،
              القدرات التشغيلية، وحالات الاستخدام الملائمة لمشروعكم.
            </p>
            <div class="solutionsPage__heroActions">
              <a class="btn btn--primary" href="/contact-us">اطلب استشارة مشروع</a>
            </div>

            <ul class="solutionsPage__heroStats" aria-label="إحصاءات موجزة">
              <li>
                <strong><%= solutions.length %></strong>
                <span>حلول متخصصة</span>
              </li>
              <li>
                <strong>+40%</strong>
                <span>تحسين كفاءة التشغيل</span>
              </li>
              <li>
                <strong>24/7</strong>
                <span>دعم وتشغيل مستمر</span>
              </li>
            </ul>

            <ul class="solutionsPage__heroBadges" aria-label="مزايا تشغيلية">
              <li>تصميم وتنفيذ بمعايير احترافية</li>
              <li>تكامل بين الأنظمة في منصة موحّدة</li>
              <li>قابلية توسع مستقبلية حسب نمو المشروع</li>
            </ul>
          </div>

          <div class="solutionsPage__heroMedia" aria-hidden="true">
            <figure class="solutionsPage__heroPrimary">
              <img src="/assets/solutions/smart-building.webp" alt="" loading="lazy" />
            </figure>
            <div class="solutionsPage__heroStack">
              <figure><img src="/assets/solutions/smart-office.webp" alt="" loading="lazy" /></figure>
              <figure><img src="/assets/solutions/security-Systems.webp" alt="" loading="lazy" /></figure>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="solutions-catalog">
        <div class="container">
          <div class="section__head">
            <p class="solutionsPage__sectionKicker">SOLUTIONS CATALOG</p>
            <h2>اختر الحل المناسب ثم استعرض صفحته التفصيلية</h2>
            <p>كل بطاقة تفتح صفحة مستقلة تحتوي على شرح أعمق للحل، الميزات، وحالات الاستخدام المقترحة.</p>
          </div>

          <%- include('partials/solutions-grid', { items: solutions }) %>
        </div>
      </section>

      <%- include('partials/final-cta', { 
        heading: 'هل تحتاج دمج أكثر من حل في مشروع واحد؟',
        subheading: 'فريق اتكس يساعدك ببناء خارطة تنفيذ متكاملة تربط الأنظمة والحلول على مراحل واضحة وقابلة للتوسع.',
        mainAction: '<a class="btn btn--primary" href="/contact-us">ابدأ المناقشة الفنية</a>',
        cardHeading: 'استشارة فنية مجانية',
        cardDesc: 'أرسل نوع المشروع والمساحة والقطاع المستهدف وسنقترح لك الحلول المناسبة خلال وقت قصير.'
      }) %>
    </main>

    <%- include('partials/site-footer', { content }) %>
  </body>
</html>
